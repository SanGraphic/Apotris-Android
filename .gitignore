main/apotris/build-android/*.h
main/apotris/build-android/version.h
main/apotris/build-android/subprojects/

# Splash frame PNGs (generated by build.ps1 from video)
main/apotris/build-android/project/app/src/main/res/drawable-nodpi/splash_f*.png

