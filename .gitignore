# Generated Meson cross file (paths from local NDK)
main/apotris/meson/android-arm64-auto.ini

# Universal / multi-ABI build (separate from build-android; see build-universal.ps1)
main/apotris/build-android-universal/
main/apotris/meson/universal-generated/

