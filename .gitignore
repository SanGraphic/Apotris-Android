tools/decompile/apktool-phone/
tools/decompile/jadx-phone/
tools/decompile/jadx-app/
tools/decompile/jadx.zip

# Gradle + NDK (generated under build-android/project)
main/apotris/build-android/project/.gradle/
main/apotris/build-android/project/build/
main/apotris/build-android/project/app/build/
main/apotris/build-android/project/.cxx/
